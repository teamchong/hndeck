{
  "name": "hndeck",
  "description": "TweetDeck-style Hacker News reader with on-device AI filtering via Chrome's Gemini Nano, personal learning project",
  "type": "module",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamchong/hndeck.git"
  },
  "bugs": "https://github.com/teamchong/hndeck/issues",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --port 4330",
