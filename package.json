    "astro": "astro",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/dom-chromium-ai": "^0.0.16",
    "typescript": "^6.0.3",
